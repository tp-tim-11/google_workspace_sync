{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/Projects/team-project/Backend/**": "allow"
    },
    "read": {
      "*": "allow",
      "**.env": "deny",
      "**key.json": "deny",
    },
    "edit": {
      "*": "allow",
      "~/Projects/team-project/Backend/**": "deny"
    },
    "bash": {
      "*": "allow",
      "~/Projects/team-project/Backend/**": "ask",
      "**.env": "deny",
      "**key.json": "deny",
    }
  }
}
