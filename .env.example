GOOGLE_SERVICE_ACCOUNT_CREDENTIALS_FILE=./credentials/google_service_account_api_key.json
GOOGLE_DRIVE_DOCUMENTS_FOLDER_ID=replace-with-documents-folder-id

# Drive pull behavior
# Files from nested subfolders are flattened into DRIVE_DOWNLOAD_ROOT.
DRIVE_DOWNLOAD_ROOT=./drive_mirror
DRIVE_RECURSIVE=true
DRIVE_HARD_DELETE=true

# Optional: sheet -> postgres sync
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE=Sheet1!A:E
DB_HOST=localhost
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432
DB_SSLMODE=prefer
