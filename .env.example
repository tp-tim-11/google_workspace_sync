GOOGLE_SERVICE_ACCOUNT_CREDENTIALS_FILE=./credentials/google_service_account_api_key.json
GOOGLE_DRIVE_DOCUMENTS_FOLDER_ID=replace-with-documents-folder-id

# Drive pull behavior
# Files from nested subfolders keep their Drive folder structure.
DRIVE_DOWNLOAD_ROOT=./drive_mirror
DRIVE_STATE_FILE=./drive_sync_state.json
DRIVE_RECURSIVE=true
DRIVE_HARD_DELETE=true
DRIVE_INGEST_ENABLED=true
DRIVE_INGEST_STATE_FILE=./uc2_ingest_state.json
DRIVE_INGEST_WORKERS=2
KLUKY_MCP_PROJECT_ROOT=../kluky_mcp

# Optional: sheet -> postgres sync
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE=Sheet1!A:F
DB_HOST=localhost
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432
DB_SSLMODE=prefer
SHEET_PUSH_POLL_TIMEOUT_SECONDS=30
